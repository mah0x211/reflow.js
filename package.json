{
    "name": "@mah0x211/reflow",
    "version": "0.0.0-dev",
    "description": "An attribute-based, no-eval HTML template engine that renders x-* attributes into HTML on Node.js and Cloudflare Workers.",
    "license": "MIT",
    "keywords": [
        "template-engine",
        "html-template",
        "ssr",
        "server-side-rendering",
        "cloudflare-workers",
        "workerd",
        "htmx",
        "no-eval",
        "declarative",
        "html",
        "attributes",
        "reflow"
    ],
    "homepage": "https://github.com/mah0x211/reflow.js#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mah0x211/reflow.js.git"
    },
    "bugs": {
        "url": "https://github.com/mah0x211/reflow.js/issues"
    },
    "type": "module",
    "main": "./src/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "workerd": "./src/index.workers.js",
            "node": "./src/index.js",
            "default": "./src/index.js"
        }
    },
    "files": [
        "src",
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "test": "node --test 'test/**/*.test.js'",
        "test:coverage": "c8 --reporter=text --reporter=lcov --reporter=html --include='src/**/*.js' --exclude='src/htmlrewriter.node.js' --exclude='src/htmlrewriter.workers.js' --exclude='src/index.workers.js' node --test 'test/**/*.test.js'",
        "check": "tsc -p jsconfig.json",
        "build:types": "rm -rf dist && tsc -p tsconfig.build.json",
        "prepublishOnly": "npm run build:types",
        "bench": "node bench/index.js"
    },
    "dependencies": {
        "html-rewriter-wasm": "^0.4.1",
        "json5": "^2.2.3"
    },
    "devDependencies": {
        "c8": "^11.0.0",
        "mitata": "^1.0.34",
        "typescript": "^5.5.0"
    },
    "engines": {
        "node": ">=24"
    },
    "publishConfig": {
        "access": "public"
    }
}
